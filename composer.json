{
    "name": "christianjbrown/php-code-quality-scripts",
    "type": "project",
    "require": {
        "php": "~8.2",
        "ext-mbstring": "*",
        "escapestudios/symfony2-coding-standard": "^3.13",
        "friendsofphp/php-cs-fixer": "^3.52",
        "squizlabs/php_codesniffer": "^3.9"
    },
    "bin": [
        "src/php-cs",
        "src/php-cs-diff",
        "src/php-cs-fix",
        "src/php-cs-fix-diff"
    ],
    "scripts": {
        "setup-standards": [
            "./bin/phpcs --config-set installed_paths `pwd`/config > /dev/null",
            "./bin/phpcs --config-set default_standard `pwd`/config/ChristianBrown.xml > /dev/null"
        ],
        "post-install-cmd": [
            "@setup-standards"
        ],
        "post-update-cmd": [
            "@setup-standards"
        ]
    },
    "config": {
        "bin-dir": "bin"
    }
}
