{
    "name": "christianjbrown/code-quality-scripts",
    "description": "An opinionated PHP_CodeSniffer standard and PHP CS Fixer rule sets (risky and safe), with shell wrappers, for keeping PHP projects to PSR, Symfony, PEAR and Generic standards.",
    "type": "library",
    "license": "MIT",
    "keywords": ["php-cs-fixer", "phpcs", "coding-standard", "code-quality", "static-analysis"],
    "authors": [
        {
            "name": "Christian Brown"
        }
    ],
    "require": {
        "php": "^8.5",
        "ext-mbstring": "*",
        "ext-xdebug": "*",
        "friendsofphp/php-cs-fixer": "^3.74",
        "squizlabs/php_codesniffer": "^4.0.1",
        "slevomat/coding-standard": "^8.30",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.2.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.0"
    },
    "bin": [
        "src/php-cs",
        "src/php-cs-diff",
        "src/php-cs-fix",
        "src/php-cs-fix-diff"
    ],
    "autoload": {
        "psr-4": {
            "ChristianBrown\\CodeQualityScripts\\PhpStan\\": "src/PhpStan/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ChristianBrown\\CodeQualityScripts\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": [
            "clear && XDEBUG_MODE=coverage php -d memory_limit=-1 ./bin/phpunit && open ./.phpunit.cache/code-coverage-html/index.html"
        ],
        "stan": [
            "clear && ./bin/phpstan analyse"
        ],
        "check-style": [
            "clear && ./src/php-cs ./config ./src/PhpStan ./tests"
        ],
        "check-style-diff": [
            "clear && ./src/php-cs-diff"
        ],
        "fix-style": [
            "clear && ./src/php-cs-fix ./config ./src/PhpStan ./tests"
        ],
        "fix-style-diff": [
            "clear && ./src/php-cs-fix-diff"
        ],
        "setup-standards": [
            "./bin/phpcs --config-set installed_paths `pwd`/vendor/slevomat/coding-standard,`pwd`/config > /dev/null",
            "./bin/phpcs --config-set default_standard `pwd`/config/standard.xml > /dev/null"
        ],
        "post-install-cmd": [
            "@setup-standards"
        ],
        "post-update-cmd": [
            "@setup-standards"
        ]
    },
    "config": {
        "bin-dir": "bin",
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
