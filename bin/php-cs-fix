#!/bin/bash
ROOT_DIR=$(dirname "$BASH_SOURCE")/..
PHP_CS_FIXER=$ROOT_DIR/vendor/bin/php-cs-fixer

FILES=${1:-$(pwd)}
if [ -z "$PHP_CS_FIX_CONFIG" ]; then
  # If not set, use a default value
  PHP_CS_FIX_CONFIG=$ROOT_DIR/rule-sets/risky.php
fi

echo "Running php-cs-fixer on $FILES with config from $PHP_CS_FIX_CONFIG ..."
$PHP_CS_FIXER fix $FILES -vvv --config=$PHP_CS_FIX_CONFIG
