#!/bin/bash

THIS_DIR=$(dirname "${BASH_SOURCE[0]}")
ROOT_DIR="$THIS_DIR/.."

if [ -z "$PHP_CS_FIXER" ]; then
  if test -f "$ROOT_DIR/../../../bin/php-cs-fixer"; then
      PHP_CS_FIXER="$ROOT_DIR/../../../bin/php-cs-fixer"
  elif test -f "$ROOT_DIR/../../../vendor/bin/php-cs-fixer"; then
      PHP_CS_FIXER="$ROOT_DIR/../../../vendor/bin/php-cs-fixer"
  elif test -f "$ROOT_DIR/bin/php-cs-fixer"; then
      PHP_CS_FIXER="$ROOT_DIR/bin/php-cs-fixer"
  else
      echo "No PHP CS Fixer executable set, and defaults not found in normal location." 1>&2
      exit 1
  fi
elif ! test -f "$PHP_CS_FIXER"; then
  echo "PHP CS Fixer executable $PHP_CS_FIXER not found." 1>&2
  exit 1
fi

if [ -z "$*" ]; then
  FILES=$(pwd)
else
  FILES=$*
fi

if [ -z "$PHP_CS_FIX_CONFIG" ]; then
  if test -f "$ROOT_DIR/config/fix-risky.php"; then
      PHP_CS_FIX_CONFIG="$ROOT_DIR/config/fix-risky.php"
  else
      echo "No PHP CS Fixer rules file set, and defaults not found in normal location." 1>&2
      exit 1
  fi
elif ! test -f "$PHP_CS_FIX_CONFIG"; then
  echo "PHP CS Fixer rules file $PHP_CS_FIX_CONFIG not found." 1>&2
  exit 1
fi

echo "Running php-cs-fixer on $FILES with rules file $PHP_CS_FIX_CONFIG ..."
$PHP_CS_FIXER fix $FILES -vvv --config="$PHP_CS_FIX_CONFIG"
