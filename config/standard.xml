<?xml version="1.0"?>
<ruleset name="ChristianBrown">

    <arg name="tab-width" value="4" />
    <arg value="p" />
    <arg value="s" />
    <arg name="colors" />

    <!--
        PHP_CodeSniffer 4 ruleset.

        The escapestudios/symfony2-coding-standard "Symfony" ref used up to v1 was
        PHP_CodeSniffer 3 only (it hard-`conflicts` cs>=4) so it has been removed. Its
        formatting sniffs were already owned by php-cs-fixer (see config/Risky.php /
        config/Safe.php — @PhpCsFixer, @Symfony, @PSR12 and the :risky variants); its
        genuine lint value is replaced below by slevomat sniffs plus the two built-in
        naming sniffs it used to pull in transitively (Zend.NamingConventions.ValidVariableName
        and Squiz.Classes.ValidClassName, the latter via PSR1/PSR2).

        The global excludes and severity-0 suppressions that used to live on the removed
        Symfony <rule> block are re-applied on the standalone PEAR blocks below, so the set
        of reported violations is unchanged from v1 aside from the intentional slevomat adds.
    -->

    <!-- ===== Preserved built-in rules (unchanged from the v1 standard.xml) ===== -->

    <rule ref="Generic.Arrays.DisallowLongArraySyntax" />
    <rule ref="Generic.CodeAnalysis.AssignmentInCondition" />
    <rule ref="Generic.CodeAnalysis.EmptyPHPStatement" />
    <rule ref="Generic.CodeAnalysis.JumbledIncrementer" />
    <rule ref="Generic.CodeAnalysis.UnconditionalIfStatement" />
    <rule ref="Generic.CodeAnalysis.UnnecessaryFinalModifier" />
    <rule ref="Generic.CodeAnalysis.UselessOverridingMethod" />
    <rule ref="Generic.Commenting.DocComment">
        <exclude name="Generic.Commenting.DocComment.MissingShort" />
        <exclude name="Generic.Commenting.DocComment.ShortNotCapital" />
        <exclude name="Generic.Commenting.DocComment.TagValueIndent" />
    </rule>
    <rule ref="Generic.ControlStructures.InlineControlStructure" />
    <rule ref="Generic.Files.LineLength">
        <exclude name="Generic.Files.LineLength.TooLong"/>
    </rule>
    <rule ref="Generic.Files.OneInterfacePerFile" />
    <rule ref="Generic.Files.OneObjectStructurePerFile" />
    <rule ref="Generic.Files.OneTraitPerFile" />
    <rule ref="Generic.NamingConventions.ConstructorName" />
    <rule ref="Generic.PHP.CharacterBeforePHPOpeningTag" />
    <rule ref="Generic.PHP.DeprecatedFunctions" />
    <rule ref="Generic.PHP.ForbiddenFunctions" />
    <rule ref="Generic.PHP.Syntax" />
    <rule ref="Generic.Strings.UnnecessaryStringConcat">
        <properties>
            <property name="allowMultiline" value="true" />
        </properties>
    </rule>
    <rule ref="Generic.VersionControl.GitMergeConflict" />
    <rule ref="Generic.WhiteSpace.IncrementDecrementSpacing" />
    <rule ref="Generic.WhiteSpace.LanguageConstructSpacing" />
    <rule ref="Generic.WhiteSpace.ScopeIndent">
        <properties>
            <property name="exact" value="true" />
            <property name="ignoreIndentationTokens" type="array">
                <element value="T_COMMENT" />
                <element value="T_DOC_COMMENT_OPEN_TAG" />
            </property>
        </properties>
    </rule>
    <rule ref="PEAR.Commenting.ClassComment">
        <!-- Class doc comments are not required (was excluded on the removed Symfony block) -->
        <exclude name="PEAR.Commenting.ClassComment.Missing" />
        <!-- We do not use these class tags -->
        <exclude name="PEAR.Commenting.ClassComment.MissingCategoryTag" />
        <exclude name="PEAR.Commenting.ClassComment.MissingPackageTag" />
        <exclude name="PEAR.Commenting.ClassComment.MissingAuthorTag" />
        <exclude name="PEAR.Commenting.ClassComment.MissingLicenseTag" />
        <exclude name="PEAR.Commenting.ClassComment.MissingLinkTag" />
    </rule>
    <rule ref="PEAR.Commenting.FunctionComment">
        <!-- Function doc comments are not required (was excluded on the removed Symfony block) -->
        <exclude name="PEAR.Commenting.FunctionComment.Missing" />

        <!-- We do not require param comments -->
        <exclude name="PEAR.Commenting.FunctionComment.MissingParamComment" />

        <exclude name="PEAR.Commenting.FunctionComment.MissingReturn" />
        <exclude name="PEAR.Commenting.FunctionComment.MissingParamTag" />

        <!-- Duplicate functionality of the former Symfony.Commenting.FunctionComment.MissingParamName -->
        <exclude name="PEAR.Commenting.FunctionComment.MissingParamName" />
        <exclude name="PEAR.Commenting.FunctionComment.SpacingAfterParamType" />
        <exclude name="PEAR.Commenting.FunctionComment.ExtraParamComment" />
    </rule>
    <rule ref="PEAR.Commenting.InlineComment" />
    <rule ref="PEAR.ControlStructures.ControlSignature" />
    <rule ref="PEAR.ControlStructures.MultiLineCondition" />
    <rule ref="PEAR.Files.IncludingFile" />
    <rule ref="PEAR.Functions.FunctionDeclaration" />
    <rule ref="PEAR.NamingConventions.ValidFunctionName">
        <!-- escapestudios disabled this (severity 0); Symfony style, not PEAR underscores -->
        <exclude name="PEAR.NamingConventions.ValidFunctionName.PrivateNoUnderscore" />
    </rule>
    <rule ref="PSR1" />
    <rule ref="PSR2" />

    <!--
        The two naming sniffs the removed Symfony ref used to pull in transitively.
        Squiz.Classes.ValidClassName arrives via PSR1/PSR2; Zend.NamingConventions.ValidVariableName
        is referenced explicitly here. The escapestudios severity-0 suppression of the
        MemberVarContainsNumbers message is re-applied as an exclude.
    -->
    <rule ref="Zend.NamingConventions.ValidVariableName">
        <exclude name="Zend.NamingConventions.ValidVariableName.MemberVarContainsNumbers" />
        <!--
            escapestudios suppressed these (severity 0) in v1: Symfony style does not use
            leading underscores on private members nor forbid digits in variable names.
            Re-applied here as excludes so the reported-violation set is unchanged from v1.
        -->
        <exclude name="Zend.NamingConventions.ValidVariableName.PrivateNoUnderscore" />
        <exclude name="Zend.NamingConventions.ValidVariableName.ContainsNumbers" />
    </rule>

    <!-- ===== slevomat lint sniffs (replacing the escapestudios "Symfony" unique value) ===== -->

    <!--
        Complete native type hints + phpdoc<->signature consistency
        (replaces Symfony.Commenting.TypeHinting + Symfony.Commenting.Annotations).
    -->
    <rule ref="SlevomatCodingStandard.TypeHints.ParameterTypeHint" />
    <rule ref="SlevomatCodingStandard.TypeHints.ReturnTypeHint" />
    <rule ref="SlevomatCodingStandard.TypeHints.PropertyTypeHint" />

    <!--
        Remove unused use statements. searchAnnotations=true so uses referenced only in
        @throws/@param/@var phpdoc are not false-flagged (~47 such uses across the estate).
    -->
    <rule ref="SlevomatCodingStandard.Namespaces.UnusedUses">
        <properties>
            <property name="searchAnnotations" value="true" />
        </properties>
    </rule>
    <!--
        Ordered import/use statements. caseSensitive=false matches php-cs-fixer's
        ordered_imports (sort_algorithm=alpha), which compares case-insensitively
        (strcasecmp). Keeping the two in agreement is what stops the fixer<->sniffer
        import-ordering drift that previously reddened main (issue #19).
    -->
    <rule ref="SlevomatCodingStandard.Namespaces.AlphabeticallySortedUses">
        <properties>
            <property name="caseSensitive" value="false" />
        </properties>
    </rule>
    <!-- Redundant use of a class from the current namespace -->
    <rule ref="SlevomatCodingStandard.Namespaces.UseFromSameNamespace" />
    <!--
        Every class must be abstract or final. Cannot express the entity/exception
        carve-outs, so consumers exclude it per-path for entities (see README / Phase 2).
        This repo's config/*.php are namespace-less return-scripts (not classes) and its
        tests are final, so it does not flag here.
    -->
    <rule ref="SlevomatCodingStandard.Classes.RequireAbstractOrFinal" />

    <!-- ===== Architecture metrics (unchanged) ===== -->

    <rule ref="Generic.Metrics.CyclomaticComplexity">
        <properties>
            <property name="complexity" value="8" />
            <property name="absoluteComplexity" value="10" />
        </properties>
    </rule>
    <rule ref="Generic.Metrics.NestingLevel">
        <properties>
            <property name="nestingLevel" value="5" />
            <property name="absoluteNestingLevel" value="10" />
        </properties>
    </rule>
</ruleset>
