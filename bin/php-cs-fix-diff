#!/bin/bash

ROOT_DIR=$(dirname "${BASH_SOURCE[0]}")/..
PHP_CS_FIXER=$ROOT_DIR/vendor/bin/php-cs-fixer

SINCE_COMMIT=${1:-HEAD}

if [ -z "$PHP_CS_FIX_CONFIG_SAFE" ]; then
  # For now, we use the same config for safe and risky, see README.md
  PHP_CS_FIX_CONFIG_SAFE=$ROOT_DIR/rule-sets/risky.php
fi
if [ -z "$PHP_CS_FIX_CONFIG_RISKY" ]; then
  PHP_CS_FIX_CONFIG_RISKY=$ROOT_DIR/rule-sets/risky.php
fi

pushd "$(git rev-parse --show-toplevel)" || exit

# Existing files
for file in $(git diff --name-only --diff-filter=MR "$SINCE_COMMIT"); do
	# git diff allow us to use --diff-filter and a commit, where as git status and git ls-files does not
	if [[ $file == *\.php ]]; then
		if php -l "$file"; then
			$PHP_CS_FIXER fix "$file" --config="$PHP_CS_FIX_CONFIG_SAFE"
		else
			echo "\033[0;31mLinting fail in $file\033[0m"
			exit
		fi
	fi
done

# New files (can be riskier rules)
for file in $(git diff --name-only --diff-filter=ACX "$SINCE_COMMIT"); do
	# git diff allow us to use --diff-filter and a commit, where as git status and git ls-files does not
	if [[ $file == *\.php ]]; then
		if php -l "$file"; then
			$PHP_CS_FIXER fix "$file" --config="$PHP_CS_FIX_CONFIG_RISKY"
		else
			echo "\033[0;31mLinting fail in $file\033[0m"
			exit 1
		fi
	fi
done

# Untracked files (can be riskier rules)
for file in $(git ls-files -o); do
	if [[ $file == *\.php ]]; then
		if php -l "$file"; then
			$PHP_CS_FIXER fix "$file" --config="$PHP_CS_FIX_CONFIG_RISKY"
		else
			echo "\033[0;31mLinting fail in $file\033[0m"
			exit 1
		fi
	fi
done

popd || exit
